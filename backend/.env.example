# Bu dosya ÖRNEKTİR — gerçek anahtarları BURAYA yazmayın.
# Kendi bilgisayarınızda `.env` oluşturup değerleri oraya yapıştırın.

# GitHub kişisel erişim token'ı:
# — Kendi reponda doğrudan dal/commit/PR için Contents + Pull requests (Read/write).
# — Başkasının PUBLIC reposunda fork → PR için fork oluşturma + fork üzerinde aynı izinler.
GITHUB_TOKEN=ghp_your_github_personal_access_token

# Google AI Studio veya Vertex üzerinden Gemini API anahtarı
GEMINI_API_KEY=your_gemini_api_key

# İsteğe bağlı: README için kullanılacak model (boş bırakılırsa kod sırayla güncel modelleri dener)
# GEMINI_MODEL=gemini-2.5-flash

# İsteğe bağlı: birden fazla kökeni virgülle ayırın
# FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
